# Copy this to .env.development.local for faster dev experience

# Medusa Backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Performance: Skip type checking in dev for faster builds (types checked in IDE)
# Uncomment to enable:
# TSC_COMPILE_ON_ERROR=true
# NEXT_TELEMETRY_DISABLED=1

# Cache optimizations
# These are enabled by default in Next.js 15, but you can tune them:
# NEXT_PRIVATE_STANDALONE=true
